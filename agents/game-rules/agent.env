# NVIDIA NIM Configuration
# Get your key from: https://build.nvidia.com/explore/discover
NVIDIA_NIM_API_KEY="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"

# OpenRouter Config
OPENROUTER_API_KEY=""

# LM Studio Config (local provider, no API key required)
LM_STUDIO_BASE_URL="http://localhost:1234/v1"

# Llama.cpp Config (local provider, no API key required)
LLAMACPP_BASE_URL="http://localhost:8080/v1"

# Model mappings - All Claude model requests use these models
# Format: provider_type/model/name
# Valid providers: "nvidia_nim" | "open_router" | "lmstudio" | "llamacpp"
MODEL_OPUS="nvidia_nim/meta/llama-3.1-405b-instruct"
MODEL_SONNET="nvidia_nim/meta/llama-3.1-70b-instruct"
MODEL_HAIKU="nvidia_nim/meta/llama-3.1-8b-instruct"

# Default model for game rules generation (recommend MODEL_SONNET)
MODEL="meta/llama-3.1-70b-instruct"

# NIM Settings for thinking/reasoning models
NIM_ENABLE_THINKING=true

# Output
OUTPUT_DIR=../../games
